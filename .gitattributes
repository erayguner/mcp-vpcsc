# Auto-detect text files and normalise line endings
* text=auto eol=lf

# Python
*.py text diff=python
*.pyi text diff=python

# Web / config
*.json text
*.yml text
*.yaml text
*.toml text
*.cfg text
*.ini text

# Shell
*.sh text eol=lf

# Docker
Dockerfile text
.dockerignore text

# Terraform
*.tf text diff=hcl
*.tfvars text diff=hcl

# Documentation
*.md text diff=markdown
*.txt text
LICENSE text

# Lock files — treat as binary for cleaner diffs
uv.lock binary

# Images
*.png binary
*.jpg binary
*.gif binary
*.ico binary
