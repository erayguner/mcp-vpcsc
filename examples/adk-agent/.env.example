# ── Google AI Studio (API key mode) ──────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-api-key-here

# ── OR: Vertex AI (project mode) ────────────────────────────────────────────
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=europe-west2

# ── MCP Server Connection ───────────────────────────────────────────────────
# "local" = start MCP server as subprocess (default)
# "remote" = connect to deployed Cloud Run MCP server via proxy
VPCSC_MCP_MODE=local

# Only needed when VPCSC_MCP_MODE=remote
# Start the proxy first: gcloud run services proxy vpcsc-mcp --region=europe-west2 --port=3000
# VPCSC_MCP_URL=http://localhost:3000/mcp

# ── Model Selection ─────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
